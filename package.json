{
  "name": "qacloud-qa-project",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test:e2e": "playwright test --config=config/playwright.config.ts",
    "test:e2e:headed": "playwright test --config=config/playwright.config.ts --headed",
    "test:e2e:market": "playwright test --config=config/playwright.config.ts src/e2e/market/",
    "test:e2e:hotel": "playwright test --config=config/playwright.config.ts src/e2e/hotel/",
    "test:api": "playwright test --config=config/playwright.api.config.ts",
    "test:smoke": "playwright test --config=config/playwright.config.ts --grep @smoke",
    "report:generate": "allure generate reports/allure-results -o reports/allure-report --clean",
    "report:open": "allure open reports/allure-report",
    "report:serve": "allure serve reports/allure-results",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
